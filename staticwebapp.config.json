{
  "mimeTypes": {
    ".pdf": "application/pdf"
  },
  "globalHeaders": {
    "X-Content-Type-Options": "nosniff",
    "Cache-Control": "public, max-age=86400"
  },
  "routes": [
    {
      "route": "/*.pdf",
      "headers": {
        "Content-Type": "application/pdf",
        "Content-Disposition": "attachment; filename=Bewerbungsmappe_Salim_Ez-Zouaq.pdf"
      }
    },
    {
      "route": "/*",
      "serve": "/index.html",
      "statusCode": 200
    }
  ]
}
